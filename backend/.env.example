# ─────────────────────────────────────────────────────────────────────────────
# AskMyDocs Backend — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Neon.tech) ──────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?ssl=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/askmydocs?ssl=require

# ── Groq LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-70b-8192

# ── ML Models (defaults work — change only if you want a different model) ─────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=20
TOP_N_RERANK=3
RRF_K=60

# ── CORS (your Vercel frontend URL) ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Ragas CI Thresholds ───────────────────────────────────────────────────────
RAGAS_FAITHFULNESS_THRESHOLD=0.70
RAGAS_RELEVANCE_THRESHOLD=0.70
RAGAS_CONTEXT_PRECISION_THRESHOLD=0.65
RAGAS_CONTEXT_RECALL_THRESHOLD=0.65

# ── Server ────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
APP_VERSION=1.0.0
